enum ClassType {
    LIVE
    RECORDED
}

enum ClassStatus {
    UPCOMING
    ONGOING
    ENDED
}

model BatchClass {
    id            String      @id @default(uuid())
    batchId       String
    instructorId  String
    title         String
    description   String?
    startTime     DateTime
    duration      Int
    zoomMeetingId String?     @unique
    zoomJoinUrl   String?
    zoomStartUrl  String?
    recordingUrl  String?
    status        ClassStatus @default(UPCOMING)
    classStatus   ClassType   @default(LIVE)
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt
    batch         Batch       @relation(fields: [batchId], references: [id])
}
